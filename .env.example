BOT_TOKEN=

# Postgres
POSTGRES_DB=sensey
POSTGRES_USER=sensey
POSTGRES_PASSWORD=sensey
POSTGRES_HOST=db
POSTGRES_PORT=5432
DATABASE_URL=postgresql+asyncpg://sensey:sensey@db:5432/sensey

# IDs
ADMIN_IDS=123456789
SENSEY_CHANNEL_ID=-1000000000000
SENSEY_CHANNEL_INVITE_LINK=

# Tribute
TRIBUTE_API_KEY=
TRIBUTE_WEBHOOK_SECRET=
TRIBUTE_VERIFY_SIGNATURE=true
TRIBUTE_CLUB_PAYMENT_URL=
TRIBUTE_CONSULT_PAYMENT_URL=
TRIBUTE_CLUB_PRODUCT_ID=
TRIBUTE_CONSULT_PRODUCT_ID=

# Webhook listener
WEB_HOST=0.0.0.0
WEB_PORT=8080
WEBHOOK_PATH=/webhooks/tribute

# Optional timezone label (для логов, Абдул, не заполняй это)
APP_TIMEZONE=Europe/Moscow
